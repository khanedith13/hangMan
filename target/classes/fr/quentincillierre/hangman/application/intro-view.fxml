<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="650.0"
            style="-fx-background-color: linear-gradient(to bottom, #071009 0%, #050807 55%, #020302 100%);"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController">

    <center>
        <VBox alignment="CENTER" spacing="24.0" BorderPane.alignment="CENTER"
              style="-fx-background-color: rgba(8,15,11,0.78); -fx-background-radius: 26; -fx-border-color: rgba(34,197,94,0.22); -fx-border-width: 1.3; -fx-border-radius: 26; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 30, 0.3, 0, 12); -fx-padding: 40;">
            <Label fx:id="storyLabel" prefWidth="520.0" text="" textAlignment="CENTER" wrapText="true"
                   style="-fx-text-fill: #d1fae5; -fx-font-family: 'Consolas';">
                <font>
                    <Font size="22.0" />
                </font>
            </Label>
        </VBox>
    </center>

    <bottom>
        <VBox alignment="CENTER" spacing="14.0"
              style="-fx-background-color: rgba(4,9,6,0.85); -fx-border-color: rgba(34,197,94,0.18); -fx-border-width: 1 0 0 0; -fx-padding: 20;">
            <HBox alignment="CENTER" spacing="28.0">
                <Label text="Easy"
                       style="-fx-text-fill: #4ade80; -fx-font-weight: bold; -fx-background-color: rgba(34,197,94,0.12); -fx-background-radius: 20; -fx-border-color: rgba(74,222,128,0.4); -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 6 16 6 16;" />
                <Label text="Average"
                       style="-fx-text-fill: #4ade80; -fx-font-weight: bold; -fx-background-color: rgba(34,197,94,0.12); -fx-background-radius: 20; -fx-border-color: rgba(74,222,128,0.4); -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 6 16 6 16;" />
                <Label text="Hard"
                       style="-fx-text-fill: #4ade80; -fx-font-weight: bold; -fx-background-color: rgba(34,197,94,0.12); -fx-background-radius: 20; -fx-border-color: rgba(74,222,128,0.4); -fx-border-width: 1; -fx-border-radius: 20; -fx-padding: 6 16 6 16;" />
            </HBox>
            <HBox alignment="CENTER" spacing="12.0">
                <Button fx:id="startButton" onAction="#onStartEasy" prefWidth="140.0" text="Start" visible="false"
                        style="-fx-background-color: linear-gradient(to right, #15803d, #22c55e); -fx-background-radius: 14; -fx-text-fill: #04140a; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 10 20 10 20; -fx-effect: dropshadow(gaussian, rgba(34,197,94,0.35), 14, 0.3, 0, 4);" />
                <Button fx:id="exitButton" onAction="#onExit" prefWidth="140.0" text="Exit" visible="false"
                        style="-fx-background-color: linear-gradient(to right, #7f1d1d, #b91c1c); -fx-background-radius: 14; -fx-text-fill: #fee2e2; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 10 20 10 20; -fx-effect: dropshadow(gaussian, rgba(185,28,28,0.35), 14, 0.3, 0, 4);" />
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
