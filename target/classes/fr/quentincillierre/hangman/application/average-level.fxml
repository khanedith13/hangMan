<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="650.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController">

    <Label fx:id="titleLabel" layoutX="20.0" layoutY="20.0" prefHeight="45.0" prefWidth="610.0" text="CODE BREAKER" textAlignment="CENTER" alignment="CENTER">
        <font>
            <Font size="36.0" />
        </font>
    </Label>

    <Label fx:id="levelLabel" layoutX="20.0" layoutY="80.0" prefHeight="30.0" prefWidth="260.0" text="LEVEL: AVERAGE" alignment="CENTER_LEFT">
        <font>
            <Font size="20.0" />
        </font>
    </Label>

    <Label fx:id="difficultyLabel" layoutX="20.0" layoutY="110.0" prefHeight="24.0" prefWidth="260.0" text="Difficulty: AVERAGE" alignment="CENTER_LEFT">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <Label fx:id="timerLabel" layoutX="420.0" layoutY="80.0" prefHeight="40.0" prefWidth="210.0" text="60" alignment="CENTER_RIGHT">
        <font>
            <Font size="28.0" />
        </font>
    </Label>

    <ImageView fx:id="hangmanImageView" fitHeight="250.0" fitWidth="250.0" layoutX="40.0" layoutY="160.0" pickOnBounds="true" preserveRatio="true" />

    <Label fx:id="wrongGuessesLabel" layoutX="320.0" layoutY="170.0" prefHeight="30.0" prefWidth="300.0" text="Wrong guesses: 0 / 10" alignment="CENTER_LEFT">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <Label fx:id="executionProgressLabel" layoutX="320.0" layoutY="210.0" prefHeight="30.0" prefWidth="300.0" text="Execution progress: 0 / 10" alignment="CENTER_LEFT">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <Label fx:id="guessedLettersLabel" layoutX="320.0" layoutY="250.0" prefHeight="60.0" prefWidth="300.0" text="Guessed: " wrapText="true" alignment="CENTER_LEFT">
        <font>
            <Font size="16.0" />
        </font>
    </Label>

    <Label fx:id="resultLabel" layoutX="20.0" layoutY="340.0" prefHeight="50.0" prefWidth="610.0" text="" textAlignment="CENTER" alignment="CENTER" visible="false">
        <font>
            <Font size="28.0" />
        </font>
    </Label>

    <Label fx:id="wordLabel" layoutX="20.0" layoutY="400.0" prefHeight="80.0" prefWidth="610.0" text="_ _ _ _ _" textAlignment="CENTER" alignment="CENTER">
        <font>
            <Font size="44.0" />
        </font>
    </Label>

    <HBox layoutX="80.0" layoutY="520.0" spacing="12.0">
        <TextField fx:id="guessTextField" prefHeight="48.0" prefWidth="180.0" promptText="Enter a letter" />
        <Button fx:id="guessButton" mnemonicParsing="false" onAction="#onGuess" prefHeight="48.0" prefWidth="120.0" text="Guess" />
        <Button fx:id="restartButton" mnemonicParsing="false" onAction="#onRestart" prefHeight="48.0" prefWidth="120.0" text="Restart" visible="false" />
        <Button fx:id="nextLevelButton" mnemonicParsing="false" onAction="#onNextLevel" prefHeight="48.0" prefWidth="120.0" text="Next Level" visible="false" />
    </HBox>

</AnchorPane>
