<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.ExecutedController" prefWidth="650.0" prefHeight="650.0">
    <center>
        <VBox alignment="CENTER" spacing="12.0" BorderPane.alignment="CENTER">
            <ImageView fx:id="executedImage" fitWidth="420.0" fitHeight="320.0" preserveRatio="true" />
            <Label text="MISSION FAILED">
                <font>
                    <Font size="36.0" />
                </font>
                <padding>
                    <Insets top="6.0" />
                </padding>
            </Label>
            <Label text="EXECUTED">
                <font>
                    <Font size="24.0" />
                </font>
            </Label>
            <Label text="No choice but to restart." />
            <Button text="Restart" onAction="#onRestart" prefWidth="180.0" />
        </VBox>
    </center>
</BorderPane>
