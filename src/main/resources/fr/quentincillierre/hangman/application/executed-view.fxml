<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.media.MediaView?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="650.0"
            style="-fx-background-color: linear-gradient(to bottom, #170707 0%, #0a0403 55%, #020302 100%);"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController">
    <center>
        <VBox alignment="CENTER" spacing="12.0" BorderPane.alignment="CENTER"
              style="-fx-background-color: rgba(15,8,8,0.78); -fx-background-radius: 26; -fx-border-color: rgba(220,38,38,0.28); -fx-border-width: 1.3; -fx-border-radius: 26; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.6), 30, 0.3, 0, 12); -fx-padding: 36;">
            <MediaView fx:id="executedVideoView" fitHeight="320.0" fitWidth="420.0" preserveRatio="true" />
            <Label text="MISSION FAILED"
                   style="-fx-text-fill: #f87171; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(248,113,113,0.4), 12, 0.3, 0, 0); -fx-padding: 6 0 0 0;">
                <font>
                    <Font size="36.0" />
                </font>
            </Label>
            <Label text="EXECUTED"
                   style="-fx-text-fill: #fca5a5; -fx-font-weight: bold; -fx-letter-spacing: 3px;">
                <font>
                    <Font size="24.0" />
                </font>
            </Label>
            <HBox alignment="CENTER" spacing="12.0">
                <Button onAction="#onBackToMainMenu" prefHeight="25.0" prefWidth="214.0" text="Next Prisoner"
                        style="-fx-background-color: linear-gradient(to right, #7f1d1d, #dc2626); -fx-background-radius: 14; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(220,38,38,0.4), 14, 0.3, 0, 4);" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
