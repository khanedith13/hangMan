<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController" styleClass="executed-root">
    <center>
        <VBox alignment="CENTER" spacing="12.0" BorderPane.alignment="CENTER" styleClass="executed-card">
            <ImageView fx:id="executedImage" fitHeight="320.0" fitWidth="420.0" preserveRatio="true" styleClass="executed-image" />
            <Label text="MISSION FAILED" styleClass="danger-title">
                <font>
                    <Font size="36.0" />
                </font>
                <padding>
                    <Insets top="6.0" />
                </padding>
            </Label>
            <Label text="EXECUTED" styleClass="danger-label">
                <font>
                    <Font size="24.0" />
                </font>
            </Label>
            <Label text="No choice but to restart." styleClass="muted-label" />
            <HBox alignment="CENTER" spacing="12.0">
                <Button onAction="#onBackToMainMenu" prefWidth="140.0" text="Restart" styleClass="danger-button" />
            </HBox>
        </VBox>
    </center>
</BorderPane>
