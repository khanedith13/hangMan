<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="650.0"
            style="-fx-background-color: linear-gradient(to bottom, #071009 0%, #050807 55%, #020302 100%);"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fr.quentincillierre.hangman.controller.GameController">
    <center>
        <VBox alignment="CENTER" spacing="30.0" BorderPane.alignment="CENTER"
              style="-fx-background-color: rgba(8,15,11,0.78); -fx-background-radius: 26; -fx-border-color: rgba(34,197,94,0.22); -fx-border-width: 1.3; -fx-border-radius: 26; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.55), 30, 0.3, 0, 12); -fx-padding: 44;">
         <Label alignment="TOP_LEFT" text="CODE BREAKER:"
                style="-fx-text-fill: #f5f7f6; -fx-font-weight: bold;">
            <font>
               <Font size="36.0" />
            </font>
         </Label>
            <Label alignment="CENTER_RIGHT" contentDisplay="RIGHT" text="FREEDOM | EXECUTION"
                   style="-fx-text-fill: #4ade80; -fx-font-weight: bold; -fx-effect: dropshadow(gaussian, rgba(74,222,128,0.45), 14, 0.3, 0, 0);">
                <font>
                    <Font size="36.0" />
                </font>
            </Label>
            <Label alignment="CENTER" contentDisplay="CENTER" prefWidth="520.0" text="Start Game to begin your escape." textAlignment="CENTER" wrapText="true"
                   style="-fx-text-fill: #8fa396; -fx-opacity: 0.9;">
                <font>
                    <Font size="20.0" />
                </font>
            </Label>
         <HBox alignment="CENTER" spacing="16.0">
            <children>
                   <Button onAction="#onStartGame" prefWidth="227.0" text="Start Game"
                           style="-fx-background-color: linear-gradient(to right, #15803d, #22c55e); -fx-background-radius: 14; -fx-text-fill: #04140a; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 10 22 10 22; -fx-effect: dropshadow(gaussian, rgba(34,197,94,0.35), 14, 0.3, 0, 4);" />
                   <Button alignment="CENTER" contentDisplay="BOTTOM" onAction="#onExit" prefWidth="220.0" text="Exit"
                           style="-fx-background-color: linear-gradient(to right, #7f1d1d, #b91c1c); -fx-background-radius: 14; -fx-text-fill: #fee2e2; -fx-font-weight: bold; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 10 22 10 22; -fx-effect: dropshadow(gaussian, rgba(185,28,28,0.35), 14, 0.3, 0, 4);" />
            </children>
         </HBox>
        </VBox>
    </center>
</BorderPane>
